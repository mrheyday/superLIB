# ShellCheck Configuration
# https://www.shellcheck.net/wiki/

# Default shell dialect
shell=bash

# Severity: error, warning, info, style
severity=warning

# Enable all checks by default
enable=all

# Disable specific checks
# SC1091: Not following sourced files (husky)
# SC2034: Variable appears unused (may be used in sourced files)
disable=SC1091,SC2034

# Source paths for sourced files
source-path=SCRIPTDIR

# External sources (don't warn about these)
external-sources=true
