# Deployment Configuration
# Copy this file to .env and fill in the values

# Private key of deployer account (NEVER commit this!)
PRIVATE_KEY=0x...

# RPC URLs
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io:443

# Alternative RPC providers
ALCHEMY_ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_SEPOLIA_RPC=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY

# Etherscan API Keys
ETHERSCAN_API_KEY=YOUR_KEY
ARBISCAN_API_KEY=YOUR_KEY

# Contract Addresses
# Option 1: Self-deployed (costs ~0.1 ETH for deployment)
# SNIPER_SEARCHER_ADDRESS=0x...
# FLASH_LOAN_RECEIVER_ADDRESS=0x...
# DELEGATED_EXECUTOR_ADDRESS=0x...

# Option 2: Use pre-deployed bebe (canonical, no cost)
# DELEGATED_EXECUTOR_ADDRESS=0x00000000BEBEDB7C30ee418158e26E31a5A8f3E2
# Set USE_EXTERNAL_DELEGATEE=true if using external bebe
USE_EXTERNAL_DELEGATEE=false

# Uniswap V3 SwapRouter02 (same on mainnet and testnet)
SWAP_ROUTER=0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45

# Aave V3 Lending Pool Addresses
AAVE_POOL_ARBITRUM=0x794a61358D6845594F94dc1DB02A252b5b4814aD
AAVE_POOL_SEPOLIA=0xB9c5a95A8F8d7ad8e64D64Ef53e6aBaA40A5Bf18
