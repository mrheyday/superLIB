# Arbitrage Protocol - Production Deployment Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED: Ownership & Security
# ═══════════════════════════════════════════════════════════════════════════════

# Gnosis Safe address (3-of-5 multisig recommended)
# This will be the owner of all contracts and the RolesAuthority
OWNER_SAFE=0x...

# Emergency guardian address (fast-response EOA for pause operations)
# This address can pause the vault but cannot unpause or withdraw
GUARDIAN_EOA=0x...

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED: Protocol Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Underlying asset token address (e.g., USDC, WETH)
ASSET_TOKEN=0x...

# Fee recipient address (defaults to OWNER_SAFE if not set)
FEE_RECIPIENT=0x...

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: AI Agent Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Autonomous execution agent address
# Will receive: EXECUTOR, CROSSCHAIN_OPERATOR, VAULT_DEPOSITOR roles
# Will NOT receive: ADMIN, RISK_MANAGER, STRATEGY_MANAGER, FEE_UPDATER, WHITELIST_ADMIN
AI_AGENT=0x...

# ═══════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT: Network Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# RPC endpoints
MAINNET_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Deployment private key (will NOT become owner - only used for deployment tx)
DEPLOYER_PRIVATE_KEY=0x...

# Etherscan API keys for verification
ETHERSCAN_API_KEY=...
ARBISCAN_API_KEY=...
BASESCAN_API_KEY=...

# ═══════════════════════════════════════════════════════════════════════════════
# EXAMPLE VALUES (Mainnet USDC)
# ═══════════════════════════════════════════════════════════════════════════════
# ASSET_TOKEN=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
