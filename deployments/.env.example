# Production Deployment Configuration
# Copy to .env and fill in values

# Required: Gnosis Safe multisig (3-of-5 recommended)
OWNER_MULTISIG=0x...

# Required: Guardian EOA for emergency pause
GUARDIAN_ADDRESS=0x...

# Optional: AI agent address (leave empty to skip)
AI_AGENT_ADDRESS=0x...

# Required: Vault underlying asset (USDC, WETH, etc)
ASSET_TOKEN=0x...

# Optional: Fee recipient (defaults to OWNER_MULTISIG)
FEE_RECIPIENT=0x...

# Network RPC URLs
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Etherscan API keys for verification
ETHERSCAN_API_KEY=YOUR_KEY
ARBISCAN_API_KEY=YOUR_KEY
BASESCAN_API_KEY=YOUR_KEY

# Deployer private key (NEVER commit this)
PRIVATE_KEY=0x...
