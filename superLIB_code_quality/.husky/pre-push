#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🚀 Running pre-push checks..."

# Full test suite with coverage
echo "🧪 Running full test suite..."
forge test -vvv
if [ $? -ne 0 ]; then
    echo "❌ Tests failed. Push aborted."
    exit 1
fi

# Gas snapshot check
echo "⛽ Checking gas snapshot..."
forge snapshot --check 2>/dev/null
if [ $? -ne 0 ]; then
    echo "⚠️  Gas snapshot differs. Consider updating with 'forge snapshot'"
fi

# Invariant tests
echo "🔬 Running invariant tests..."
forge test --match-path "test/*Invariant*" -vv
if [ $? -ne 0 ]; then
    echo "❌ Invariant tests failed. Push aborted."
    exit 1
fi

echo "✅ All pre-push checks passed!"
