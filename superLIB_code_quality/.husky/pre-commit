#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Format check
echo "📝 Checking formatting..."
forge fmt --check
if [ $? -ne 0 ]; then
    echo "❌ Formatting check failed. Run 'forge fmt' to fix."
    exit 1
fi

# Lint
echo "🔎 Running linter..."
forge lint 2>/dev/null || true

# Build
echo "🔨 Building..."
forge build --sizes
if [ $? -ne 0 ]; then
    echo "❌ Build failed."
    exit 1
fi

# Test
echo "🧪 Running tests..."
forge test
if [ $? -ne 0 ]; then
    echo "❌ Tests failed."
    exit 1
fi

# Security patterns check
echo "🔒 Checking security patterns..."
if grep -rn "tx\.origin" src/ --include="*.sol" 2>/dev/null; then
    echo "⚠️  Warning: tx.origin usage detected"
fi

if grep -rn "selfdestruct\|suicide" src/ --include="*.sol" 2>/dev/null; then
    echo "⚠️  Warning: selfdestruct usage detected"
fi

echo "✅ All pre-commit checks passed!"
